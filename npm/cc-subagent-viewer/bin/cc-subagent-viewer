#!/usr/bin/env node

"use strict";

const { spawnSync } = require("child_process");
const path = require("path");

// Platform/arch to npm package name mapping
const PLATFORM_MAP = {
  "darwin-arm64": "cc-subagent-viewer-darwin-arm64",
  "darwin-x64": "cc-subagent-viewer-darwin-x64",
  "linux-x64": "cc-subagent-viewer-linux-x64",
  "linux-arm64": "cc-subagent-viewer-linux-arm64",
};

function getBinaryPath() {
  // Allow override via environment variable
  const envPath = process.env.CC_SUBAGENT_VIEWER_BINARY_PATH;
  if (envPath) {
    return envPath;
  }

  const platformKey = `${process.platform}-${process.arch}`;
  const packageName = PLATFORM_MAP[platformKey];

  if (!packageName) {
    console.error(
      `エラー: サポートされていないプラットフォームです: ${process.platform} ${process.arch}\n` +
      `サポート対象: ${Object.keys(PLATFORM_MAP).join(", ")}`
    );
    process.exit(1);
  }

  try {
    // Resolve the binary path from the platform-specific package
    const packageDir = path.dirname(require.resolve(`${packageName}/package.json`));
    return path.join(packageDir, "bin", "subagent-viewer");
  } catch (e) {
    console.error(
      `エラー: プラットフォームパッケージ ${packageName} が見つかりません。\n` +
      `npm install を再実行してください。`
    );
    process.exit(1);
  }
}

const binaryPath = getBinaryPath();
const result = spawnSync(binaryPath, process.argv.slice(2), {
  stdio: "inherit",
});

if (result.error) {
  console.error(`エラー: バイナリの実行に失敗しました: ${result.error.message}`);
  process.exit(1);
}

process.exit(result.status ?? 1);
